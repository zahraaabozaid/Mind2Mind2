# Or Groq (OpenAI-compatible): https://console.groq.com/keys — key starts with gsk_
VITE_GROQ_API_KEY=

# ─── Feature: Group Masterclasses (Stripe) ───────────────────────────────────
# Get these from your Stripe dashboard: https://dashboard.stripe.com/apikeys
